DATABASE_URL=postgresql://postgres:password@db:5432/zenith
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Server-level OKX credentials (used only for public market-data calls)
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# HD wallet seed (BIP-39 mnemonic) — used to derive unique USDT deposit
# addresses for each user.  Generate with:  python -c "from eth_account.hdaccount import generate_mnemonic; print(generate_mnemonic(12, lang='english'))"
HD_WALLET_SEED=

# Ethereum JSON-RPC endpoint for the blockchain listener worker
ETH_RPC_URL=https://cloudflare-eth.com

# USDT ERC-20 contract address (Ethereum mainnet)
USDT_CONTRACT_ADDRESS=0xdAC17F958D2ee523a2206206994597C13D831ec7

# How often the blockchain listener polls for new blocks (seconds)
BLOCKCHAIN_POLL_INTERVAL=30

# How often the market listener refreshes MACD signals (seconds)
MARKET_POLL_INTERVAL=60
