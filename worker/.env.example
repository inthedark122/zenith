# Trading Worker — Environment Variables
# Copy this file to .env and fill in the values.

# Railway PostgreSQL public connection string (from Railway dashboard → postgres service → Variables → DATABASE_URL)
DATABASE_URL=postgresql://postgres:password@<host>.railway.app:5432/railway?sslmode=require

# Must match the SECRET_KEY set on the Railway backend service
SECRET_KEY=changeme

# How often (seconds) the worker polls the market and dispatches strategies
MARKET_POLL_INTERVAL=60
