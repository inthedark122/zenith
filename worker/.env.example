# Trading Worker — Environment Variables
# Copy this file to .env on the GCP VM at /opt/zenith-worker/.env

# Railway PostgreSQL public connection string
# Find it: Railway dashboard → postgres service → Variables → DATABASE_URL
DATABASE_URL=postgresql://postgres:password@<host>.railway.app:5432/railway?sslmode=require

# Must match the SECRET_KEY set on the Railway backend service
SECRET_KEY=changeme

# How often (seconds) the worker polls the market and dispatches strategies
MARKET_POLL_INTERVAL=60

# Docker image to run — updated automatically by GitHub Actions on each deploy
# Format: REGION-docker.pkg.dev/PROJECT_ID/zenith/zenith-worker:SHA
WORKER_IMAGE=asia-southeast1-docker.pkg.dev/YOUR_PROJECT_ID/zenith/zenith-worker:latest
